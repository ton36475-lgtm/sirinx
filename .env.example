# SIRINX root environment template
# Copy to `.env` only when you are ready to wire real services.
# Leave secrets blank in source control.

# -----------------------------------------------------------------------------
# Local runtime control
# -----------------------------------------------------------------------------
# Optional. The dev server defaults to 3000 if unset.
PORT=3000

# Optional. Used by the governed server receiver scripts to render the reverse-proxy
# config after the approved public hostname is confirmed.
PUBLIC_PRIMARY_HOST=sirinx.co
PUBLIC_SERVER_ALIASES=www.sirinx.co
OPS_PUBLIC_HOST=ops.sirinx.co
TLS_CERT_BASENAME=sirinx.co
SIRINX_PUBLIC_BASE_URL=https://sirinx.co

# Optional. Local fallback inbox for public lead submissions when DATABASE_URL is absent.
# Keep this out of source control; it may contain customer contact data.
SIRINX_LOCAL_QUEUE_DIR=

# -----------------------------------------------------------------------------
# Database / Drizzle
# -----------------------------------------------------------------------------
# Optional for public local boot.
# Required for DB-backed mutations, admin data, analytics persistence, and drizzle commands.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Manus / OAuth / session auth
# -----------------------------------------------------------------------------
# Required for real sign-in flows and protected/admin routes.
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
JWT_SECRET=

# Optional. Used to auto-upgrade the owner account to admin when openId matches.
OWNER_OPEN_ID=

# -----------------------------------------------------------------------------
# Forge / Manus built-in platform services
# -----------------------------------------------------------------------------
# Optional for public local boot.
# Required for chatbot, notifications, storage, server-side maps proxy, image generation,
# and voice transcription integrations.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# -----------------------------------------------------------------------------
# Frontend integrations
# -----------------------------------------------------------------------------
# Optional. Falls back to the public LINE OA URL when unset.
VITE_LINE_OA_URL=https://line.me/R/ti/p/@sirinx

# Optional. Only needed if the Google Maps component is enabled in a live page.
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional. Used by the analytics script tag in client/index.html.
# Leaving these unset is safe for local recovery, but Vite will warn during build/dev.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Hermes brain-skill and server bootstrap
# -----------------------------------------------------------------------------
# Optional. Server-local paths used by Hermes brain bootstrap and mentor packets.
HERMES_RUNTIME_ROOT=
BRAIN_SKILL_ROOT=
AGENT_PACKET_ROOT=

# Optional stage flags for governed server-side continuation.
SIRINX_STAGE_DATABASE=0
SIRINX_STAGE_HERMES=1
