# SIRINX local frontend override template
# Copy to `.env.local` for Vite-only local overrides.
# Server-side code loads `.env` via dotenv/config, so server secrets still belong in `.env`.

# Safe local defaults for recovery work
VITE_LINE_OA_URL=https://line.me/R/ti/p/@sirinx

# Optional frontend-only integrations
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
