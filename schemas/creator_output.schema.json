{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIRINX Creator Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "surface", "headline", "support_points", "claim_boundary"],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "surface": { "type": "string", "enum": ["public-site", "internal-brief", "server-handoff", "executive-summary"] },
    "headline": { "type": "string", "minLength": 1 },
    "support_points": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "claim_boundary": { "type": "string", "minLength": 1 },
    "review_notes": { "type": "array", "items": { "type": "string" } }
  }
}

