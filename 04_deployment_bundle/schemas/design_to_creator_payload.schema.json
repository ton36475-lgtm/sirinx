  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIRINX Design To Creator Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "approved_design_rules", "fact_boundary_notes", "copy_targets"],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "approved_design_rules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "fact_boundary_notes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "copy_targets": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "media_reference_paths": { "type": "array", "items": { "type": "string" } }
  }
}

