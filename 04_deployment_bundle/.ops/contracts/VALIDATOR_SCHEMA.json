{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIRINX Validator Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assigned_agent",
    "workflow_stage",
    "schema_ok",
    "paths_exist",
    "fact_lock_passed",
    "handoff_ready",
    "failures",
    "validated_paths",
    "recommended_next_agent"
  ],
  "properties": {
    "assigned_agent": {
      "const": "Validator"
    },
    "workflow_stage": {
      "const": "validate"
    },
    "schema_ok": {
      "type": "boolean"
    },
    "paths_exist": {
      "type": "boolean"
    },
    "fact_lock_passed": {
      "type": "boolean"
    },
    "handoff_ready": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validated_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_agent": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "Hermes",
        "Creator",
        "Delivery",
        null
      ]
    }
  }
}
